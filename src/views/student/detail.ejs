<h1 class="text-2xl font-bold mb-6">Detail Student</h1>

<div class="bg-white p-6 rounded shadow max-w-lg">

  <p class="mb-2">
    <span class="font-semibold">Nama:</span>
    <%= student.fullName %>
  </p>

  <h2 class="font-semibold mt-4 mb-2">Course yang diambil:</h2>

  <% if (student.courses.length) { %>
    <ul class="list-disc pl-6">
      <% student.courses.forEach(course => { %>
        <li><%= course.name %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="text-gray-500">Belum mengambil course</p>
  <% } %>

  <div class="mt-6 flex gap-2">
    <a href="/student/edit/<%= student.id %>"
       class="bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600">
      Edit
    </a>

    <a href="/student"
       class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
      Kembali
    </a>
  </div>
</div>