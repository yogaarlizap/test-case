<h1 class="text-2xl font-bold mb-6">Tambah Student</h1>

<form action="/student" method="POST" class="bg-white p-6 rounded shadow max-w-lg">

  <div class="mb-4">
    <label class="block mb-1 font-semibold">Nama</label>
    <input type="text" name="fullName" required
           class="w-full border rounded px-3 py-2">
  </div>

  <div class="mb-4">
    <label class="block mb-1 font-semibold">Course</label>
    <select name="courseId[]" multiple
            class="w-full border rounded px-3 py-2 h-32">
      <% courses.forEach(course => { %>
        <option value="<%= course.id %>">
          <%= course.name %>
        </option>
      <% }) %>
    </select>
    <p class="text-sm text-gray-500 mt-1">
      Tekan Ctrl / Cmd untuk memilih lebih dari satu
    </p>
  </div>

  <div class="flex gap-2">
    <button type="submit"
            class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">
      Simpan
    </button>

    <a href="/students"
       class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600">
      Batal
    </a>
  </div>

</form>