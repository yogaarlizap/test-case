<h1 class="text-2xl font-bold mb-6">Edit Student</h1>

<form action="/student/<%= student.id %>?_method=PUT"
      method="POST"
      class="bg-white p-6 rounded shadow max-w-lg">

  <div class="mb-4">
    <label class="block mb-1 font-semibold">Nama</label>
    <input type="text"
           name="fullName"
           value="<%= student.fullName %>"
           required
           class="w-full border rounded px-3 py-2">
  </div>

  <div class="mb-4">
    <label class="block mb-1 font-semibold">Course</label>
    <select name="courseId[]"
            multiple
            class="w-full border rounded px-3 py-2 h-32">

      <% courses.forEach(course => { %>
        <option value="<%= course.id %>"
          <%= student.courses.some(c => c.id === course.id) ? 'selected' : '' %>>
          <%= course.name %>
        </option>
      <% }) %>

    </select>
  </div>

  <div class="flex gap-2">
    <button type="submit"
            class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">
      Update
    </button>

    <a href="/student/<%= student.id %>"
       class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
      Batal
    </a>
  </div>
</form>